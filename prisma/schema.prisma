generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum ClientStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum OfferType {
  HIVE_EXPERIENCE
  THE_PASSAGE
  SOUVERAINETE
}

enum ProtocolStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum SessionType {
  ONLINE
  PRESENTIAL
  CEREMONY
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  role           Role
  name           String
  lastLoginAt    DateTime? // Dernière connexion — pour "Today's Activity"
  dailyRecapTime String    @default("18:00") // Heure du récapitulatif de journée (HH:mm)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client           Client?
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  pendingActions   PendingAction[]
}

model Client {
  id                    String       @id @default(uuid())
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                ClientStatus @default(ACTIVE)
  offerType             OfferType
  startDate             DateTime     @default(now())
  nextSessionDate       DateTime?
  notes                 String?      // Notes internes Joffrey — NON visible client
  onboardingCompleted   Boolean      @default(false) // Onboarding formulaire rempli
  hdType                String?      // Type Human Design (GENERATOR, MANIFESTOR, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journalEntries        JournalEntry[]
  elixirPrescriptions   ElixirPrescription[]
  protocols             Protocol[]
  sessions              Session[]
  supports              Support[]
  dailyRecommendations  DailyRecommendation[]
  dailyFocuses          DailyFocus[]
  clientRecommendations ClientRecommendation[]
  pendingActions        PendingAction[]
  documents             ClientDocument[]
  intake                ClientIntake?
  analysis              ClientAnalysis?
  journeyMessageLogs    JourneyMessageLog[]
  clientPractices       ClientPractice[]
}

model JournalEntry {
  id        String  @id @default(uuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  content   String
  isPrivate Boolean @default(false) // true = visible uniquement par le client
  mood      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Elixir {
  id          String   @id @default(uuid())
  name        String
  description String
  dosage      String
  duration    String
  stock       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prescriptions ElixirPrescription[]
}

model ElixirPrescription {
  id             String   @id @default(uuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  elixirId       String
  elixir         Elixir   @relation(fields: [elixirId], references: [id], onDelete: Cascade)
  dosage         String?  // Override possible (texte descriptif)
  quantity       Int?     // Quantité totale prescrite (ex: 60 capsules)
  dailyDose      Float?   // Dose journalière (ex: 2 unités/jour)
  startDate      DateTime @default(now())
  endDate        DateTime? // Calculé ou manuel
  reorderUrl     String?  // Lien direct pour recommander
  stockAlertDays Int      @default(7) // Jours avant épuisement pour alerter
  notes          String?

  createdAt DateTime @default(now())
}

model Protocol {
  id          String         @id @default(uuid())
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  frequency   String?
  duration    String?
  status      ProtocolStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id             String        @id @default(uuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  duration       Int           // en minutes
  type           SessionType
  status         SessionStatus @default(SCHEDULED)
  zoomLink       String?       // Lien Zoom pour les sessions en ligne
  notes          String?       // Notes privées — Joffrey uniquement
  checklistItems String?       // JSON array de checklist items [{text, done}]
  recapDone      Boolean       @default(false) // Récap de fin de journée fait

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  sender     User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  tag        String?   // "SYMPTOM" pour les rapports symptômes prioritaires
  readAt     DateTime?

  createdAt DateTime @default(now())
}

model InviteToken {
  id        String    @id @default(uuid())
  token     String    @unique @default(uuid())
  email     String
  role      Role      @default(CLIENT)
  offerType OfferType
  usedAt    DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
}

// Ressources partagées par Joffrey avec un client (musique, vidéo, PDF, liens)
enum SupportType {
  MUSIC
  VIDEO
  PDF
  LINK
}

model Support {
  id          String      @id @default(uuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  type        SupportType
  url         String      // URL vers la ressource
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Recommandations quotidiennes par client (matin / soir) configurables par Joffrey
model DailyRecommendation {
  id        String @id @default(uuid())
  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dayFrom   Int    // Jour de début dans le programme (inclus)
  dayTo     Int    // Jour de fin dans le programme (inclus)
  slot      String // "MORNING" ou "EVENING"
  title     String
  content   String // Consignes / recommandations

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Focus du jour par client — message quotidien basé sur la progression
model DailyFocus {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dayFrom  Int    // Jour de début (inclus)
  dayTo    Int    // Jour de fin (inclus)
  title    String
  message  String // Message d'intention / focus du jour

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Catalogue de recommandations produits / ressources de Joffrey
enum RecommendationCategory {
  EAU
  COMPLEMENTS
  OUTILS
  SOINS
  APITHERAPIE
  AUTRE
}

model Recommendation {
  id          String                 @id @default(uuid())
  title       String
  description String
  url         String                 // Lien affilié
  category    RecommendationCategory
  imageUrl    String?
  isGlobal    Boolean                @default(false) // Visible par tous les clients

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientRecommendations ClientRecommendation[]
}

// Attribution personnalisée d'une recommandation à un client
model ClientRecommendation {
  id               String         @id @default(uuid())
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  note             String?        // Note personnalisée de Joffrey pour ce client

  createdAt DateTime @default(now())

  @@unique([clientId, recommendationId])
}

// Actions en attente pour l'admin — générées automatiquement
enum PendingActionType {
  RECAP
  ELIXIR
  SESSION
  SYMPTOM
  CUSTOM
  DOCUMENT
  BIRTHDAY
}

model PendingAction {
  id          String            @id @default(uuid())
  adminId     String
  admin       User              @relation(fields: [adminId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        PendingActionType
  title       String
  description String?
  urgency     String            @default("green") // "red" | "amber" | "green"
  completedAt DateTime?         // null = visible · set = invisible

  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════
// MODULE — DOCUMENT VAULT
// ═══════════════════════════════════════

enum DocumentCategory {
  ANALYSE
  IDENTITE
  MEDICAL
  AUTRE
}

model ClientDocument {
  id          String           @id @default(uuid())
  clientId    String
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy  String           // "CLIENT" ou "ADMIN"
  fileName    String
  fileUrl     String
  fileSize    Int              // en bytes
  mimeType    String
  category    DocumentCategory @default(AUTRE)
  readByAdmin Boolean          @default(false)

  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════
// MODULE — ONBOARDING INTAKE + ANALYSE IA
// ═══════════════════════════════════════

model ClientIntake {
  id            String   @id @default(uuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  birthDate     DateTime
  birthTime     String?  // "HH:MM" ou null si inconnu
  birthPlace    String
  birthCountry  String
  postalAddress String
  city          String
  postalCode    String
  country       String
  intention     String   // Ce qui amène le client

  submittedAt DateTime @default(now())
}

enum AnalysisStatus {
  PENDING
  GENERATING
  COMPLETE
  ERROR
}

model ClientAnalysis {
  id                String         @id @default(uuid())
  clientId          String         @unique
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  astroWestern      String?        // JSON
  humanDesign       String?        // JSON
  numerology        String?        // JSON
  bazi              String?        // JSON
  synthesisMarkdown String?        // Synthèse narrative en markdown
  status            AnalysisStatus @default(PENDING)

  generatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════
// MODULE — MESSAGES PARCOURS AUTOMATISÉS
// ═══════════════════════════════════════

enum JourneyTriggerType {
  JOURNEY_DAY
  BIRTHDAY
  CUSTOM
}

model JourneyMessageTemplate {
  id          String             @id @default(uuid())
  title       String
  dayTrigger  Int                // Jour du parcours (1, 3, 7, etc.) ou 0 pour BIRTHDAY
  triggerType JourneyTriggerType @default(JOURNEY_DAY)
  hdVariants  String             // JSON : { GENERATOR: {subject, body}, PROJECTOR: {...}, ... DEFAULT: {...} }
  isActive    Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs JourneyMessageLog[]
}

model JourneyMessageLog {
  id          String                @id @default(uuid())
  clientId    String
  client      Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateId  String
  template    JourneyMessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sentAt      DateTime              @default(now())
  dayNumber   Int
  hdType      String                // Type HD utilisé pour le variant
  variantUsed String                // Clé du variant utilisé (GENERATOR, DEFAULT, etc.)
}

// ═══════════════════════════════════════
// MODULE — PRATIQUES (Respiration, Vidéo, Méditation)
// ═══════════════════════════════════════

enum PracticeType {
  BREATHING
  VIDEO
  MEDITATION
}

enum PracticeCategory {
  RESPIRATION
  MEDITATION
  MOUVEMENT
  RITUAL
}

model Practice {
  id          String           @id @default(uuid())
  title       String
  description String
  type        PracticeType
  content     String           // JSON — structure dépend du type
  category    PracticeCategory
  isGlobal    Boolean          @default(false)
  dayTrigger  Int?             // Jour du parcours pour auto-assign (null = manuel)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientPractices ClientPractice[]
}

model ClientPractice {
  id              String    @id @default(uuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  practiceId      String
  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  assignedAt      DateTime  @default(now())
  assignedByAdmin Boolean   @default(false)
  completedCount  Int       @default(0)
  lastCompletedAt DateTime?
  note            String?   // Note personnelle de Joffrey
  isActive        Boolean   @default(true)

  @@unique([clientId, practiceId])
}
